# Neon Postgres — get from neon.tech dashboard → Connection Details → Connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Cloudinary — get from cloudinary.com dashboard → Settings → API Keys
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Flask secret (any random string)
FLASK_SECRET_KEY=spk-mlbb-secret-key-2026
